# ============================================
# 法务审查 Agent - API 配置模板
# 复制此文件为 .env 并填写实际值
# ============================================

# LLM API 密钥（必填）
LLM_API_KEY=your-api-key-here

# LLM API 地址（必填）
LLM_API_BASE=https://token-plan-cn.xiaomimimo.com/v1

# LLM 模型名称
LLM_MODEL=mimo-v2.5-pro

# 嵌入模型配置（用于向量检索，默认 DashScope text-embedding-v3）
# EMBEDDING_API_BASE=https://dashscope.aliyuncs.com
# EMBEDDING_API_KEY=             # 空则回退 LLM_API_KEY
# EMBEDDING_MODEL=text-embedding-v3

# 最大文件大小（MB）
MAX_FILE_SIZE_MB=10

# HuggingFace 镜像（国内网络可选）
HF_ENDPOINT=https://hf-mirror.com
